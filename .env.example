# ============================================================
# VitaSync — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://vitasync:vitasync@localhost:5432/vitasync
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ───────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-in-production
ENCRYPTION_KEY=change-me-32-byte-hex-encoded-key

# Initial admin workspace credentials (auto-created on first boot)
ADMIN_WORKSPACE_SLUG=default
ADMIN_API_KEY=vs_live_changeme_for_production

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Web Dashboard ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Provider Credentials ─────────────────────────────────────
# Garmin Connect
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Fitbit
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Withings
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Polar
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Provider OAuth callback base URL
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── OpenTelemetry (optional) ─────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=vitasync-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
