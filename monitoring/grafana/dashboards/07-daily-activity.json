      "targets": [{
        "datasource": { "type": "postgres", "uid": "vitasync-pg" },
        "editorMode": "code",
        "format": "time_series",
        "rawQuery": true,
        "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', recorded_at) AS day,\n    SUM(value) AS steps\n  FROM health_metrics\n  WHERE $__timeFilter(recorded_at)\n    AND metric_type = 'steps'\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n)\nSELECT\n  day AS \"time\",\n  ROUND(steps::numeric,0)::bigint AS \"Daily Steps\",\n  ROUND((AVG(steps) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW))::numeric,0)::bigint AS \"7-day Avg\"\nFROM daily\nORDER BY day",
        "refId": "A"
      }],
      "title": "Daily Steps — Bar & 7-day Average",
      "type": "timeseries"
    },

