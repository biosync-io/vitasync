      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  TO_CHAR(day, 'Dy') AS \"Day of Week\",\n  ROUND(AVG(daily_steps)::numeric,0)::bigint AS \"Avg Steps\"\nFROM (\n  SELECT DATE_TRUNC('day', recorded_at) AS day, SUM(value) AS daily_steps\n  FROM health_metrics\n  WHERE $__timeFilter(recorded_at)\n    AND metric_type = 'steps'\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n) t\nGROUP BY EXTRACT(DOW FROM day), TO_CHAR(day, 'Dy')\nORDER BY EXTRACT(DOW FROM day)", "refId": "A" }],
      "title": "Avg Steps by Day of Week",
