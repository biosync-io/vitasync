        "overrides": [
          { "matcher": { "id": "byName", "options": "7-day Avg" }, "properties": [{ "id": "custom.drawStyle", "value": "line" }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
