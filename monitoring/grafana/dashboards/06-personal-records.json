      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  u.display_name AS \"User\",\n  pr.metric_type AS \"Metric Type\",\n  COALESCE(pr.category, '-') AS \"Category\",\n  ROUND(pr.value::numeric, 2)::float AS \"Value\",\n  COALESCE(pr.unit, '-') AS \"Unit\",\n  pr.provider_id AS \"Provider\",\n  pr.recorded_at AS \"Set On\",\n  pr.updated_at AS \"Updated\"\nFROM personal_records pr\nJOIN users u ON u.id = pr.user_id\nWHERE ('$userId' = 'all' OR pr.user_id::text = '$userId')\nORDER BY pr.recorded_at DESC\nLIMIT 200", "refId": "A" }],
      "title": "All Personal Records",
      "type": "table"
