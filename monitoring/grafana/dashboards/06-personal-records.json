      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "time_series", "rawQuery": true, "rawSql": "SELECT\n  $__timeGroupAlias(recorded_at,$__interval),\n  COUNT(*) AS \"PRs Set\"\nFROM personal_records\nWHERE $__timeFilter(recorded_at)\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nGROUP BY 1\nORDER BY 1", "refId": "A" }],
