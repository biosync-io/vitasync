      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  metric_type AS \"Metric\",\n  COUNT(*) AS \"Records\"\nFROM personal_records\nWHERE ('$userId' = 'all' OR user_id::text = '$userId')\nGROUP BY metric_type\nORDER BY 2 DESC\nLIMIT 20", "refId": "A" }],
