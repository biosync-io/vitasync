      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT ROUND((value/1000.0)::numeric,2)::float AS \"Longest Run (km)\"\nFROM personal_records\nWHERE metric_type = 'distance'\n  AND category IN ('running','run')\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nORDER BY value DESC\nLIMIT 1", "refId": "A" }],
