        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(value::numeric,1)::float AS \"Weight (kg)\"\nFROM health_metrics\nWHERE metric_type IN ('weight','body_weight')\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\n  AND value > 0\nORDER BY recorded_at DESC\nLIMIT 1",
          "refId": "A"
        }
      ],
      "title": "Latest Weight",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "kg",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ordered AS (\n  SELECT value, recorded_at,\n    ROW_NUMBER() OVER (ORDER BY recorded_at DESC) AS rn\n  FROM health_metrics\n  WHERE metric_type IN ('weight','body_weight')\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n    AND $__timeFilter(recorded_at)\n    AND value > 0\n)\nSELECT ROUND((\n  (SELECT value FROM ordered WHERE rn = 1) -\n  (SELECT value FROM ordered ORDER BY recorded_at ASC LIMIT 1)\n)::numeric,1)::float AS \"Weight Change (kg)\"",
          "refId": "A"
        }
      ],
      "title": "Weight Change (Period)",
      "type": "stat"
    },
