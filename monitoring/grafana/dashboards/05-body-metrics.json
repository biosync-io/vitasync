        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', recorded_at) AS day,\n    AVG(value) AS w\n  FROM health_metrics\n  WHERE $__timeFilter(recorded_at)\n    AND metric_type IN ('weight','body_weight')\n    AND value BETWEEN 20 AND 300\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n)\nSELECT\n  day AS \"time\",\n  ROUND(w::numeric,2)::float AS \"Weight (kg)\",\n  ROUND((AVG(w) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW))::numeric,2)::float AS \"7-day MA (kg)\",\n  ROUND((AVG(w) OVER (ORDER BY day ROWS BETWEEN 29 PRECEDING AND CURRENT ROW))::numeric,2)::float AS \"30-day MA (kg)\"\nFROM daily\nORDER BY day",
          "refId": "A"
        }
      ],
      "title": "Weight Trend with Moving Averages",
      "type": "timeseries"
    },

