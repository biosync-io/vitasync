      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', recorded_at) AS day,\n    AVG(value) AS rhr\n  FROM health_metrics\n  WHERE $__timeFilter(recorded_at)\n    AND metric_type IN ('resting_heart_rate','resting_hr')\n    AND value BETWEEN 30 AND 120\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n)\nSELECT\n  day AS \"time\",\n  ROUND(rhr::numeric,1)::float AS \"Resting HR (bpm)\",\n  ROUND((AVG(rhr) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW))::numeric,1)::float AS \"7-day Avg\"\nFROM daily\nORDER BY day",
          "refId": "A"
        }
      ],
      "title": "Resting Heart Rate Trend",
      "type": "timeseries"
    },
