          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', recorded_at) AS day,\n    AVG(value) AS hrv\n  FROM health_metrics\n  WHERE $__timeFilter(recorded_at)\n    AND metric_type IN ('hrv','heart_rate_variability')\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n)\nSELECT\n  day AS \"time\",\n  ROUND(hrv::numeric,1)::float AS \"HRV (ms)\",\n  ROUND((AVG(hrv) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW))::numeric,1)::float AS \"7-day Avg\"\nFROM daily\nORDER BY day",
