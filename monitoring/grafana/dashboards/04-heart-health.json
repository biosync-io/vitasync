          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN value < 50 THEN '< 50'\n    WHEN value < 60 THEN '50-59'\n    WHEN value < 70 THEN '60-69'\n    WHEN value < 80 THEN '70-79'\n    WHEN value < 90 THEN '80-89'\n    ELSE '90+'\n  END AS \"HR Range (bpm)\",\n  COUNT(*) AS \"Readings\"\nFROM health_metrics\nWHERE $__timeFilter(recorded_at)\n  AND metric_type IN ('resting_heart_rate','resting_hr')\n  AND value BETWEEN 30 AND 120\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nGROUP BY 1\nORDER BY MIN(value)",
          "refId": "A"
        }
