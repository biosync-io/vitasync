          "rawSql": "SELECT\n  provider_id AS \"Provider\",\n  COUNT(*) AS \"Metrics\"\nFROM health_metrics\nWHERE $__timeFilter(recorded_at)\nGROUP BY provider_id\nORDER BY 2 DESC",
