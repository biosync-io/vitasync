    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Connections Table",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [
            {
              "type": "value",
              "options": { "active": { "text": "Active", "color": "green", "index": 0 } }
            },
            {
              "type": "value",
              "options": { "error": { "text": "Error", "color": "red", "index": 1 } }
            },
            {
              "type": "value",
              "options": {
                "disconnected": { "text": "Disconnected", "color": "orange", "index": 2 }
              }
            },
            {
              "type": "value",
              "options": { "revoked": { "text": "Revoked", "color": "grey", "index": 3 } }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Provider" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Sync Lag (h)" },
            "properties": [
              { "id": "unit", "value": "h" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Status" }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pc.provider_id AS \"Provider\",\n  pc.status AS \"Status\",\n  COALESCE(u.display_name, u.email, u.external_id, pc.user_id::text) AS \"User\",\n  pc.last_synced_at AS \"Last Synced\",\n  CASE\n    WHEN pc.last_synced_at IS NULL THEN NULL\n    ELSE ROUND((EXTRACT(EPOCH FROM (NOW() - pc.last_synced_at))/3600.0)::numeric,1)::float\n  END AS \"Sync Lag (h)\",\n  pc.created_at AS \"Connected Since\"\nFROM provider_connections pc\nJOIN users u ON u.id = pc.user_id\nORDER BY pc.status, pc.last_synced_at ASC NULLS FIRST",
          "refId": "A"
        }
      ],
      "title": "All Provider Connections",
      "type": "table"
    },

