      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::bigint AS \"Stale (> 24h)\"\nFROM provider_connections\nWHERE status = 'active'\n  AND (last_synced_at IS NULL OR last_synced_at < NOW() - INTERVAL '24 hours')",
          "refId": "A"
        }
      ],
      "title": "Stale Connections (>24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
