        "displayLabels": ["name", "percent"],
        "legend": {
          "calcs": ["value"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
