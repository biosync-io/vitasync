          "rawSql": "SELECT COUNT(*)::bigint AS \"Error / Disconnected\"\nFROM provider_connections\nWHERE status NOT IN ('active')",
          "refId": "A"
        }
      ],
      "title": "Error / Disconnected",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 24 }
            ]
          },
          "unit": "h",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (NOW() - last_synced_at))/3600.0)::numeric,1)::float AS \"Avg Sync Lag (h)\"\nFROM provider_connections\nWHERE last_synced_at IS NOT NULL\n  AND status = 'active'",
          "refId": "A"
        }
      ],
      "title": "Avg Sync Lag",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
