          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(recorded_at,$__interval),\n  provider_id,\n  COUNT(*) AS \"Records\"\nFROM health_metrics\nWHERE $__timeFilter(recorded_at)\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Health Metrics Ingestion per Provider (Stacked)",
      "type": "timeseries"
