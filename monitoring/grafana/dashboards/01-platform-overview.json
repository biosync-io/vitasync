    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Recent Sync Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text",
                  "colorMode": "cell"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "options": { "completed": { "color": "green", "index": 0 } }, "type": "value" },
                  { "options": { "failed": { "color": "red", "index": 1 } }, "type": "value" },
                  { "options": { "running": { "color": "blue", "index": 2 } }, "type": "value" },
                  { "options": { "pending": { "color": "yellow", "index": 3 } }, "type": "value" }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "created_at" }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  sj.id,\n  pc.provider_id,\n  sj.status,\n  sj.metrics_synced,\n  sj.started_at,\n  sj.completed_at,\n  EXTRACT(EPOCH FROM (sj.completed_at - sj.started_at))::int AS duration_sec,\n  sj.error\nFROM sync_jobs sj\nJOIN provider_connections pc ON pc.id = sj.connection_id\nWHERE sj.created_at >= NOW() - INTERVAL '7 days'\nORDER BY sj.created_at DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Recent Sync Jobs (Last 7 Days)",
      "type": "table"
    }
