      "targets": [{ "datasource": { "type": "postgres", "uid": "vitasync-pg" }, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  started_at AS \"Date\",\n  COALESCE(title, activity_type, 'Workout') AS \"Title\",\n  COALESCE(activity_type, '-') AS \"Activity Type\",\n  ROUND((COALESCE(duration_seconds,0)/60.0)::numeric,0)::int AS \"Duration (min)\",\n  ROUND((COALESCE(distance_meters,0)/1000.0)::numeric,2)::float AS \"Distance (km)\",\n  ROUND(COALESCE(calories_kcal,0)::numeric,0)::int AS \"Calories (kcal)\",\n  COALESCE(avg_heart_rate::text, '-') AS \"Avg HR\",\n  COALESCE(max_heart_rate::text, '-') AS \"Max HR\",\n  ROUND(COALESCE(elevation_gain_meters,0)::numeric,0)::int AS \"Elevation (m)\",\n  provider_id AS \"Provider\"\nFROM events\nWHERE $__timeFilter(started_at)\n  AND event_type = 'workout'\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nORDER BY started_at DESC\nLIMIT 100", "refId": "A" }],
