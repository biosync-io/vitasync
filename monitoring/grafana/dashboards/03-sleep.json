        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  TO_CHAR(started_at, 'Dy') AS \"Day of Week\",\n  ROUND((AVG(duration_seconds)/3600.0)::numeric,1)::float AS \"Avg Sleep (h)\"\nFROM events\nWHERE $__timeFilter(started_at)\n  AND event_type = 'sleep'\n  AND duration_seconds IS NOT NULL\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nGROUP BY\n  EXTRACT(DOW FROM started_at),\n  TO_CHAR(started_at, 'Dy')\nORDER BY EXTRACT(DOW FROM started_at)",
