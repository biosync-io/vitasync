      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "min", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', started_at) AS day,\n    AVG(duration_seconds)/3600.0 AS hrs\n  FROM events\n  WHERE $__timeFilter(started_at)\n    AND event_type = 'sleep'\n    AND duration_seconds IS NOT NULL\n    AND ('$userId' = 'all' OR user_id::text = '$userId')\n  GROUP BY 1\n)\nSELECT\n  day AS \"time\",\n  ROUND(hrs::numeric,2)::float AS \"Sleep Duration (h)\",\n  ROUND((AVG(hrs) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW))::numeric,2)::float AS \"7-day Avg (h)\"\nFROM daily\nORDER BY day",
          "refId": "A"
        }
      ],
      "title": "Sleep Duration — Daily & 7-day Average",
      "type": "timeseries"
    },

