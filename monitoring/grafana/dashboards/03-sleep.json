      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "vitasync-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  started_at AS \"Bedtime\",\n  ended_at AS \"Wake Time\",\n  ROUND((COALESCE(duration_seconds,0)/3600.0)::numeric,2)::float AS \"Duration (h)\",\n  ROUND(COALESCE(calories_kcal,0)::numeric,0)::int AS \"Calories\",\n  provider_id AS \"Provider\",\n  COALESCE(notes, '-') AS \"Notes\"\nFROM events\nWHERE $__timeFilter(started_at)\n  AND event_type = 'sleep'\n  AND ('$userId' = 'all' OR user_id::text = '$userId')\nORDER BY started_at DESC\nLIMIT 60",
          "refId": "A"
        }
      ],
      "title": "Sleep Session Log",
      "type": "table"
