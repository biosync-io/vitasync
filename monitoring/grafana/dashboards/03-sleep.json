    {
      "datasource": { "type": "postgres", "uid": "vitasync-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false }
        },
        "overrides": [
