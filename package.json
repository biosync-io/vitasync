{
  "name": "vitasync",
  "version": "0.1.0",
  "private": true,
  "description": "Unified wearable health data aggregation platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "turbo run db:generate --filter=@biosync-io/db",
    "db:migrate": "turbo run db:migrate --filter=@biosync-io/db",
    "db:studio": "turbo run db:studio --filter=@biosync-io/db",
    "docs:dev": "turbo run dev --filter=@biosync-io/docs",
    "docs:build": "turbo run build --filter=@biosync-io/docs",
    "docs:preview": "turbo run preview --filter=@biosync-io/docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.4.1"
}
