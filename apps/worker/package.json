    "@biosync-io/provider-fitbit": "workspace:*",
    "@biosync-io/provider-garmin": "workspace:*",
    "@biosync-io/types": "workspace:*",
    "bullmq": "^5.7.0",
    "drizzle-orm": "^0.38.4",
    "ioredis": "5.9.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
