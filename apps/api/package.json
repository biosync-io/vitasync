{
  "name": "@biosync-io/api",
  "version": "0.1.0",
  "private": true,
  "description": "VitaSync REST API — Fastify server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts src/migrate.ts --format esm --out-dir dist && node -e \"const{cpSync,existsSync,mkdirSync}=require('fs');const src='../../packages/db/src/migrations';existsSync(src)?cpSync(src,'dist/migrations',{recursive:true}):mkdirSync('dist/migrations',{recursive:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@biosync-io/analytics": "workspace:*",
    "@biosync-io/db": "workspace:*",
    "@biosync-io/notification-core": "workspace:*",
    "@biosync-io/provider-core": "workspace:*",
    "@biosync-io/provider-fitbit": "workspace:*",
    "@biosync-io/provider-garmin": "workspace:*",
    "@biosync-io/provider-strava": "workspace:*",
    "@biosync-io/provider-whoop": "workspace:*",
    "@biosync-io/provider-withings": "workspace:^",
    "@biosync-io/types": "workspace:*",
    "@bull-board/api": "^6.20.6",
    "@bull-board/fastify": "^6.20.6",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.3",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "bullmq": "^5.27.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.9.3",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
